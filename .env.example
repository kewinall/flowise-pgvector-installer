# 此檔由 install.sh 轉成 .env。請勿將正式 .env 上傳到 Git。
FLOWISE_VERSION=3.1.3
PGVECTOR_IMAGE_TAG=0.8.4-pg17-bookworm
TZ=Asia/Taipei

FLOWISE_PORT=3000
FLOWISE_BIND_ADDRESS=0.0.0.0
APP_URL=http://SERVER_IP:3000
SECURE_COOKIES=false
TRUST_PROXY=false
NUMBER_OF_PROXIES=0

POSTGRES_ADMIN_USER=flowise_admin
POSTGRES_ADMIN_PASSWORD=CHANGE_ME
POSTGRES_DEFAULT_DB=postgres

FLOWISE_DB_NAME=flowise
FLOWISE_DB_USER=flowise_app
FLOWISE_DB_PASSWORD=CHANGE_ME

VECTOR_DB_NAME=flowise_vector
VECTOR_DB_USER=flowise_vector
VECTOR_DB_PASSWORD=CHANGE_ME

JWT_AUTH_TOKEN_SECRET=CHANGE_ME
JWT_REFRESH_TOKEN_SECRET=CHANGE_ME
EXPRESS_SESSION_SECRET=CHANGE_ME
TOKEN_HASH_SECRET=CHANGE_ME
FLOWISE_SECRETKEY_OVERWRITE=CHANGE_ME

FLOWISE_FILE_SIZE_LIMIT=100mb
SHOW_COMMUNITY_NODES=true
DISABLE_FLOWISE_TELEMETRY=true
BACKUP_RETENTION_DAYS=30
